    <script>
        // --- LOGIC ---
        document.addEventListener('DOMContentLoaded', () => {
            const slides = document.querySelectorAll('.slide');
            const navItems = document.querySelectorAll('.nav-item');
            const btnNext = document.querySelectorAll('.btn-next');
            const btnPrev = document.querySelectorAll('.btn-prev');
            const mainContent = document.querySelector('.main-content');
            let currentSlide = 0;

            // Initialize Lucide Icons
            lucide.createIcons();

            function updateSlide(index) {
                if(index < 0 || index >= slides.length) return;
                
                // Update Slides
                slides.forEach(s => s.classList.remove('active'));
                slides[index].classList.add('active');
                
                // Update Sidebar Active State
                navItems.forEach(item => {
                    item.classList.toggle('active', parseInt(item.dataset.slide) === index);
                });

                // Scroll Top
                mainContent.scrollTop = 0;
                currentSlide = index;
            }

            // Event Listeners: Sidebar
            navItems.forEach(item => {
                item.addEventListener('click', () => {
                    updateSlide(parseInt(item.dataset.slide));
                });
            });

            // Event Listeners: Buttons
            btnNext.forEach(btn => {
                btn.addEventListener('click', () => updateSlide(currentSlide + 1));
            });

            btnPrev.forEach(btn => {
                btn.addEventListener('click', () => updateSlide(currentSlide - 1));
            });

            // Event Listeners: Keyboard
            document.addEventListener('keydown', (e) => {
                if(e.key === 'ArrowRight') updateSlide(currentSlide + 1);
                if(e.key === 'ArrowLeft') updateSlide(currentSlide - 1);
                if(e.key === 'ArrowUp') {
                    e.preventDefault();
                    mainContent.scrollBy({top: -100, behavior: 'smooth'});
                }
                if(e.key === 'ArrowDown') {
                    e.preventDefault();
                    mainContent.scrollBy({top: 100, behavior: 'smooth'});
                }
            });
        });
    </script>
